# ─────────────────────────────────────────────────────────────────────
# Siftly — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────

# Database — SQLite file path (no changes needed for local dev)
DATABASE_URL="file:./prisma/dev.db"

# ── Anthropic auth ───────────────────────────────────────────────────

# Option A: Claude CLI OAuth token (free under your Claude subscription)
# Locally, the app reads this from the macOS keychain automatically — no config needed.
# In Docker, extract it manually:
#   security find-generic-password -s "Claude Code-credentials" -w \
#     | python3 -c "import sys,json; print(json.load(sys.stdin)['claudeAiOauth']['accessToken'])"
# ANTHROPIC_CLI_KEY=

# Option B: Regular Anthropic API key (pay-as-you-go)
# Get yours at: https://console.anthropic.com (starts with sk-ant-api03-)
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: custom API base URL (proxy or local model server)
# ANTHROPIC_BASE_URL=

# ── Multi-backend resolution ─────────────────────────────────────────
#
# Backend selection order:
# 1) SIFTLY_AI_BACKEND (if set)
# 2) Saved UI provider (Anthropic/OpenAI only)
# 3) Auto-detect (Claude CLI -> Codex CLI -> Anthropic default)
#
# Optional fallback chain used at resolution time if primary backend is unavailable:
# SIFTLY_AI_FALLBACK="openrouter,gemini,anthropic"
#
# Optional runtime execution fallback (off by default). If set, failed calls can retry on these backends.
# SIFTLY_AI_EXECUTION_FALLBACK="openrouter,gemini"
#
# Primary backend choices:
# anthropic | openai | openrouter | gemini | opencode | acp_cursor | acp_amp
# SIFTLY_AI_BACKEND=
#
# Optional per-backend model overrides:
# SIFTLY_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# SIFTLY_OPENAI_MODEL=gpt-5.4-mini

# ── OpenRouter ───────────────────────────────────────────────────────
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-5.4-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_REFERER=https://your-app.example
# OPENROUTER_TITLE=Siftly

# ── Gemini ───────────────────────────────────────────────────────────
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ── OpenCode Zen / Go ────────────────────────────────────────────────
# OPENCODE_API_KEY=
# IMPORTANT: pick a URL that matches your model family:
# - chat-completions models: https://opencode.ai/zen/v1/chat/completions
# - Anthropic messages models: https://opencode.ai/zen/v1/messages
# OPENCODE_CHAT_URL=https://opencode.ai/zen/v1/chat/completions
# OPENCODE_MODEL=gpt-5.4-mini

# ── ACP backends (experimental, off by default) ─────────────────────
# For security, ACP is disabled unless explicitly enabled.
# SIFTLY_EXPERIMENTAL_ACP=1
#
# Cursor ACP defaults:
# SIFTLY_ACP_CURSOR_COMMAND=agent
# SIFTLY_ACP_CURSOR_ARGS=acp
# SIFTLY_ACP_CURSOR_AUTH_METHOD=cursor_login
# SIFTLY_ACP_CURSOR_MODEL=gpt-5.4-mini
#
# Amp ACP defaults:
# SIFTLY_ACP_AMP_COMMAND=acp-amp
# SIFTLY_ACP_AMP_ARGS=
# SIFTLY_ACP_AMP_AUTH_METHOD=
# SIFTLY_ACP_AMP_MODEL=gpt-5.4-mini

# ── Backend toggles (optional) ───────────────────────────────────────
# SIFTLY_AI_ENABLE_ANTHROPIC=1
# SIFTLY_AI_ENABLE_OPENAI=1
# SIFTLY_AI_ENABLE_OPENROUTER=1
# SIFTLY_AI_ENABLE_GEMINI=1
# SIFTLY_AI_ENABLE_OPENCODE=1
# SIFTLY_AI_ENABLE_ACP_CURSOR=0
# SIFTLY_AI_ENABLE_ACP_AMP=0

# ── Access control (optional) ────────────────────────────────────────

# Set BOTH to enable HTTP Basic Auth on the entire app.
# Leave unset for unrestricted local access (the default).
# Recommended when exposing Siftly via a public URL (e.g. Cloudflare Tunnel).
# SIFTLY_USERNAME=admin
# SIFTLY_PASSWORD=your-passphrase-here
